@page "/login"
@using Blazored.LocalStorage
@using CorePulse.Client.Identity
@using CorePulse.Shared.DTOs.Requests
@using CorePulse.Shared.DTOs.Responses
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<EditForm Model="model" OnValidSubmit="HandleLoginAsync">
    <DataAnnotationsValidator />
    <div class="form-group mb-3">
        <label>Email</label>
        <InputText @bind-Value="model.Email" class="form-control" />
        <ValidationMessage For="@(() => model.Email)" />
    </div>
    <div class="form-group mb-3">
        <label>Password</label>
        <InputText @bind-Value="model.Password" type="password" class="form-control" />
        <ValidationMessage For="@(() => model.Password)" />
    </div>
    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">Login</button>
    <div class="mt-3">
        <span>Don't have an account? </span>
        <a href="/register" class="text-primary">Register here</a>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@code
{
    private LoginRequestDTO model = new();
    private string? errorMessage;
    private bool isSubmitting = false;

    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private ILocalStorageService LocalStorage { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;

    /// <summary>
    /// Handles the user login process by sending credentials to the API,
    /// storing the JWT session, and updating the global authentication state.
    /// </summary>
    public async Task HandleLoginAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            // Authenticate with the backend
            var response = await Http.PostAsJsonAsync<LoginRequestDTO>("https://localhost:7039/api/auth/login", model);

            if (response.IsSuccessStatusCode)
            {
                var session = await response.Content.ReadFromJsonAsync<UserSessionDTO>();

                // Persist the JWT and user info in browser local storage
                await LocalStorage.SetItemAsync("UserSession", session);

                // Notify the AuthenticationStateProvider that the user has successfully logged in
                var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                customProvider.NotifyUserAuthentication(session!);

                // Force a reload to ensure all components and SignalR handlers recognize the new identity
                NavManager.NavigateTo("/", forceLoad: true);
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception)
        {
            errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}